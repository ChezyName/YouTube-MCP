# YouTube Data API v3 key - no OAuth - Public Data
# Get it at: https://console.cloud.google.com → APIs & Services → Credentials
YOUTUBE_API_KEY=your_api_key_here

# OAuth 2.0 credentials (needed for analytics) - you must set your account (the one for youtube) as test user
# Get it at: https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
YOUTUBE_CLIENT_ID=your_client_id_here
YOUTUBE_CLIENT_SECRET=your_client_secret_here

# Leave blank — server will generate this on first run and save it automatically
YOUTUBE_REFRESH_TOKEN=

# Your YouTube channel handle (without @)
CHANNEL_HANDLE=YourChannelHandle

# Needed for Cloudflare Tunnel if you are using, not required but recommended
CLOUDFLARE_TUNNEL_TOKEN=your_token_here